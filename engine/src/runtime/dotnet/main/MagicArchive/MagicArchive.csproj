<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <ImplicitUsings>true</ImplicitUsings>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
      <None Update="Utilities\WellKnownTypesRegistration.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>WellKnownTypesRegistration.cs</LastGenOutput>
      </None>
        <None Update="Formatters\TupleFormatter.tt">
            <Generator>TextTemplatingFileGenerator</Generator>
            <LastGenOutput>TupleFormatter.cs</LastGenOutput>
        </None>
        <None Update="ArchiveReader.Blittable.tt">
          <Generator>TextTemplatingFileGenerator</Generator>
          <LastGenOutput>ArchiveReader.Blittable.cs</LastGenOutput>
        </None>
        <None Update="ArchiveWriter.Blittable.tt">
          <Generator>TextTemplatingFileGenerator</Generator>
          <LastGenOutput>ArchiveWriter.Blittable.cs</LastGenOutput>
        </None>
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="JetBrains.Annotations" />
      <PackageReference Include="LinkDotNet.StringBuilder" />
      <PackageReference Include="ZLinq" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="MagicArchive.Test"/>
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Utilities\WellKnownTypesRegistration.cs">
        <DependentUpon>WellKnownTypesRegistration.tt</DependentUpon>
      </Compile>
      <Compile Update="Formatters\TupleFormatter.cs">
        <AutoGen>True</AutoGen>
        <DesignTime>True</DesignTime>
        <DependentUpon>TupleFormatter.tt</DependentUpon>
      </Compile>

        <Compile Update="ArchiveReader.Blittable.cs">
            <AutoGen>True</AutoGen>
            <DesignTime>True</DesignTime>
            <DependentUpon>ArchiveReader.Blittable.tt</DependentUpon>
        </Compile>
        <Compile Update="ArchiveWriter.Blittable.cs">
            <AutoGen>True</AutoGen>
            <DesignTime>True</DesignTime>
            <DependentUpon>ArchiveWriter.Blittable.tt</DependentUpon>
        </Compile>
    </ItemGroup>
</Project>
