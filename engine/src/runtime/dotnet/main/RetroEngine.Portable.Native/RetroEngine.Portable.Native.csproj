<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>RetroEngine.Portable</AssemblyName>
        <RootNamespace>RetroEngine.Portable</RootNamespace>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Version>1.0.0-dev.4</Version>
        <PackageId>RetroEngine.Portable.Native</PackageId>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="$(RetroEnginePortableCommonProj)" />
        <ProjectReference Include="$(RetroEnginePortableSourceGeneratorProj)"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false"/>
        <ProjectReference Include="$(RetroEngineInteropProj)" />
        <ProjectReference Include="..\ZParse\ZParse.csproj" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="JetBrains.Annotations" />
        <PackageReference Include="MessagePack" />
        <PackageReference Include="System.IO.Hashing" />
        <PackageReference Include="TimeZoneNames" />
        <PackageReference Include="ZLinq" />
        <PackageReference Include="Zomp.SyncMethodGenerator">
          <PrivateAssets>all</PrivateAssets>
          <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="RetroEngine.Portable.Test"/>
    </ItemGroup>
</Project>
