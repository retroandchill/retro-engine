<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>RetroEngine.Portable</AssemblyName>
        <RootNamespace>RetroEngine.Portable</RootNamespace>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Configurations>Debug;Release;Dev-Debug;Dev-Release;Pkg-Debug;Pkg-Release;</Configurations>
        <Platforms>AnyCPU</Platforms>
        <DefineConstants>$(DefineConstants);RETRO_NAME_BACKEND_NATIVE</DefineConstants>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="$(RetroEnginePortableCommonProj)" />
        <ProjectReference Include="$(RetroEnginePortableSourceGeneratorProj)"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false"/>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="JetBrains.Annotations" />
        <PackageReference Include="MessagePack" />
        <PackageReference Include="Superpower" />
        <PackageReference Include="System.IO.Hashing" />
        <PackageReference Include="TimeZoneNames" />
        <PackageReference Include="ZLinq" />
        <PackageReference Include="Zomp.SyncMethodGenerator">
          <PrivateAssets>all</PrivateAssets>
          <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>
</Project>
