<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>true</IsPackable>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <RootNamespace>RetroEngine.Portable</RootNamespace>
        <Version>1.0.0-dev.4</Version>
        <RetroEngineVersion>1.0.0-dev.4</RetroEngineVersion>
    </PropertyGroup>
    <ItemGroup>
        <None Include="RetroEngine.Portable.targets" Pack="true" PackagePath="buildTransitive\" />
    </ItemGroup>
    <ItemGroup>
        <Compile Remove="Interop\**\*.cs" />
        <Compile Remove="Strings\**\*.cs" />
        <Compile Remove="Localization\**\*.cs" />
        <Compile Remove="Serialization\**\*.cs" />
    </ItemGroup>
</Project>
