<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>RetroEngine.Portable</AssemblyName>
        <RootNamespace>RetroEngine.Portable</RootNamespace>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Version>1.0.0-dev.4</Version>
        <PackageId>RetroEngine.Portable</PackageId>
        <ProduceReferenceAssembly>true</ProduceReferenceAssembly>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="..\RetroEngine.Interop\RetroEngine.Interop.csproj" />
        <ProjectReference Include="..\RetroEngine.Utilities\RetroEngine.Utilities.csproj" />
        <ProjectReference Include="..\RetroEngine.Utilities.SourceGenerator\RetroEngine.Utilities.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
        <ProjectReference Include="$(RetroEngineInteropProj)" />
        <ProjectReference Include="..\ZParse\ZParse.csproj" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="CsvHelper" />
        <PackageReference Include="JetBrains.Annotations" />
        <PackageReference Include="MessagePack" />
        <PackageReference Include="System.IO.Hashing" />
        <PackageReference Include="TimeZoneNames" />
        <PackageReference Include="ZLinq" />
        <PackageReference Include="Zomp.SyncMethodGenerator">
          <PrivateAssets>all</PrivateAssets>
          <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="RetroEngine.Portable.Test"/>
    </ItemGroup>

    <ItemGroup>
        <None Update="Serialization\Binary\Utilities\MultiReadExtensions.tt">
            <Generator>TextTemplatingFileGenerator</Generator>
            <LastGenOutput>MultiReadExtensions.cs</LastGenOutput>
        </None>
        <None Update="Serialization\Binary\Utilities\WellKnownTypesRegistration.tt">
            <Generator>TextTemplatingFileGenerator</Generator>
            <LastGenOutput>WellKnownTypesRegistration.cs</LastGenOutput>
        </None>
        <None Update="Serialization\Binary\Utilities\MultiWriteExtensions.tt">
          <Generator>TextTemplatingFileGenerator</Generator>
          <LastGenOutput>MultiWriteExtensions.cs</LastGenOutput>
        </None>
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Serialization\Binary\Utilities\WellKnownTypesRegistration.cs">
        <AutoGen>True</AutoGen>
        <DesignTime>True</DesignTime>
        <DependentUpon>WellKnownTypesRegistration.tt</DependentUpon>
      </Compile>
      <Compile Update="Serialization\Binary\Utilities\MultiReadExtensions.cs">
        <AutoGen>True</AutoGen>
        <DesignTime>True</DesignTime>
        <DependentUpon>MultiReadExtensions.tt</DependentUpon>
      </Compile>
      <Compile Update="Serialization\Binary\Utilities\MultiWriteExtensions.cs">
        <AutoGen>True</AutoGen>
        <DesignTime>True</DesignTime>
        <DependentUpon>MultiWriteExtensions.tt</DependentUpon>
      </Compile>
    </ItemGroup>
</Project>
