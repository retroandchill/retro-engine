<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels1="clr-namespace:RetroEngine.Editor.Core.ViewModels"
             xmlns:extensions="clr-namespace:RetroEngine.Editor.Core.Extensions"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RetroEngine.Editor.Core.Views.LaunchScreenView">
    <Design.DataContext>
        <viewModels1:LaunchScreenViewModel/>
    </Design.DataContext>

    <TabControl TabStripPlacement="Left" ItemsSource="{Binding Tabs}">
        <TabControl.ItemTemplate>
            <DataTemplate DataType="viewModels1:ILaunchScreenTabViewModel">
                <TextBlock Text="{Binding Header}"/>
            </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
            <DataTemplate DataType="viewModels1:ILaunchScreenTabViewModel">
                <ContentControl Content="{Binding}"/>
            </DataTemplate>
        </TabControl.ContentTemplate>
    </TabControl>
</UserControl>
