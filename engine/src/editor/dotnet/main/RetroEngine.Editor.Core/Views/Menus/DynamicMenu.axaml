<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:menus="clr-namespace:RetroEngine.Editor.Core.ViewModels.Menus"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RetroEngine.Editor.Core.Views.Menus.DynamicMenuView">
    <Design.DataContext>
        <menus:DynamicMenuViewModel/>
    </Design.DataContext>

    <StackPanel x:DataType="menus:DynamicMenuViewModel">
        <Menu ItemsSource="{Binding Items}">
            <Menu.Styles>
                <Style Selector="MenuItem">
                    <Setter x:DataType="menus:IDynamicMenuItem" Property="Header" Value="{Binding Header}"/>
                    <Setter x:DataType="menus:IDynamicMenuItem" Property="Command" Value="{Binding Command}"/>
                    <Setter x:DataType="menus:IDynamicMenuItem" Property="CommandParameter" Value="{Binding CommandParameter}"/>
                    <Setter x:DataType="menus:IDynamicMenuItem" Property="InputGesture" Value="{Binding Gesture}"/>
                    <Setter x:DataType="menus:IDynamicMenuItem" Property="ItemsSource" Value="{Binding Items}"/>
                </Style>
            </Menu.Styles>
        </Menu>
    </StackPanel>
</UserControl>
