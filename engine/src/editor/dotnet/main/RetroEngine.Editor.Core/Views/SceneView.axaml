<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:RetroEngine.Editor.Core.Behaviors"
             xmlns:viewModels="clr-namespace:RetroEngine.Editor.Core.ViewModels"
             xmlns:hosts="clr-namespace:RetroEngine.Editor.Core.Hosts"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RetroEngine.Editor.Core.Views.SceneView">

    <Design.DataContext>
        <viewModels:SceneViewModel/>
    </Design.DataContext>

    <Interaction.Behaviors>
        <behaviors:DisposeBehavior/>
    </Interaction.Behaviors>

    <hosts:EngineControlHost Provider="{Binding Host}"
                             Width="640"
                             Height="480"/>
</UserControl>
