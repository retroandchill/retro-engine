<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>14</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Avalonia" />
      <PackageReference Include="CommunityToolkit.Mvvm" />
      <PackageReference Include="Dock.Model.Avalonia" />
      <PackageReference Include="EFCore.NamingConventions" />
      <PackageReference Include="IconPacks.Avalonia" />
      <PackageReference Include="Injectio" />
      <PackageReference Include="JetBrains.Annotations" />
      <PackageReference Include="Microsoft.EntityFrameworkCore" />
      <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" />
      <PackageReference Include="Microsoft.Extensions.Options" />
      <PackageReference Include="Testably.Abstractions.FileSystem.Interface" />
      <ProjectReference Include="$(RetroEnginePortableSourceGeneratorProj)"
                        OutputItemType="Analyzer"
                        ReferenceOutputAssembly="false"/>
        <ProjectReference Include="$(RetroEngineEditorSourceGeneratorProj)"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false"/>
    </ItemGroup>

    <ItemGroup Condition="'$(RetroEngineBackend)' == 'Native'">
        <ProjectReference Include="$(RetroEnginePortableNativeProj)" />
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Views\Menus\DynamicMenu.axaml.cs">
        <DependentUpon>DynamicMenu.axaml</DependentUpon>
        <SubType>Code</SubType>
      </Compile>
      <Compile Update="Views\ProjectOpenView.axaml.cs">
        <DependentUpon>ProjectOpenView.axaml</DependentUpon>
        <SubType>Code</SubType>
      </Compile>
    </ItemGroup>

</Project>
