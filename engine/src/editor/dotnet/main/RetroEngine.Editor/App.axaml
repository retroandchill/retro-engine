<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RetroEngine.Editor.App"
             xmlns:core="clr-namespace:RetroEngine.Editor.Core;assembly=RetroEngine.Editor.Core"
             xmlns:converters="clr-namespace:RetroEngine.Avalonia.Converters;assembly=RetroEngine.Avalonia"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <converters:TextToStringConverter x:Key="TextToStringConverter"/>
    </Application.Resources>

    <Application.DataTemplates>
        <core:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <DockFluentTheme />
        <ToolMenuTheme/>
    </Application.Styles>
</Application>
