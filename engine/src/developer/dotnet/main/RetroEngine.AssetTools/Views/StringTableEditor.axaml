<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:RetroEngine.AssetTools.ViewModels"
             xmlns:extensions="clr-namespace:RetroEngine.Avalonia.Extensions;assembly=RetroEngine.Avalonia"
             xmlns:ic="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RetroEngine.AssetTools.Views.StringTableEditor"
             x:DataType="viewModels:StringTableEditorViewModel">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="10" RowSpacing="2">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="5">
            <TextBlock Grid.Column="0" Text="{extensions:LocalizedText StringTableEditor, Namespace, Namespace}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding Namespace}" />
            <Button Grid.Column="2">
                <TextBlock Text="{extensions:LocalizedText StringTableEditor, ImportCSV, Import from CSV}" />
            </Button>
            <Button Grid.Column="3">
                <TextBlock Text="{extensions:LocalizedText StringTableEditor, ExportCSV, Export to CSV}" />
            </Button>
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="15,10">
            <ic:FluentIcon Icon="Search" IconSize="Size24" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" HorizontalAlignment="Stretch"
                     Text="{Binding SearchTerm, Delay=100}"
                     PlaceholderText="{extensions:LocalizedText StringTableEditor, Search, Search}"/>
        </Grid>
        <ScrollViewer Grid.Row="2">
            <DataGrid ItemsSource="{Binding Entries}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{extensions:LocalizedText StringTableEditor, Key, Key}"
                                        Width="*"
                                        Binding="{Binding Key}" />
                    <DataGridTextColumn
                        Header="{extensions:LocalizedText StringTableEditor, SourceString, SourceString}"
                        Width="3*"
                        Binding="{Binding SourceString, Delay=100}"
                        IsReadOnly="False"/>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- ReSharper disable once Xaml.PossibleNullReferenceException -->
                                <Button Command="{Binding ((viewModels:StringTableEditorViewModel)DataContext).RemoveEntryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}">
                                    <ic:FluentIcon Icon="Delete"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,3*,Auto" ColumnSpacing="10">
            <TextBlock Grid.Column="0" Text="{extensions:LocalizedText StringTableEditor, Key, Key}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="KeyEntry"  Text="{Binding PendingKey}"
                     IsKeyboardFocusWithin="{Binding EditingPendingKey, Mode=OneWayToSource}"/>
            <Popup Grid.Column="1" IsOpen="{Binding ShowKeyValidationError}"
                   PlacementTarget="KeyEntry"
                   Placement="BottomEdgeAlignedRight">
                <Border Padding="8" Background="{DynamicResource NotificationCardErrorBackgroundBrush}">
                    <TextBlock Text="{Binding PendingKeyValidationError}"/>
                </Border>
            </Popup>
            <TextBlock Grid.Column="2" Text="{extensions:LocalizedText StringTableEditor, SourceString, Source String}"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="3" Text="{Binding PendingSourceString}" />
            <Button Grid.Column="4" Background="{DynamicResource AccentButtonBackground}" Command="{Binding AddEntryCommand}">
                <TextBlock Text="{extensions:LocalizedText StringTableEditor, Add, Add}" />
            </Button>
        </Grid>
    </Grid>
</UserControl>
