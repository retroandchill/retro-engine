<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:styling="clr-namespace:RetroEngine.ToolMenu.Styling"
                    x:ClassModifier="internal">
    <x:Double x:Key="{x:Static styling:ToolMenuResourceKeys.MenuSectionHeaderFontSize}">
        10
    </x:Double>

    <FontWeight x:Key="{x:Static styling:ToolMenuResourceKeys.MenuSectionHeaderFontWeight}">SemiBold</FontWeight>

    <x:Double x:Key="{x:Static styling:ToolMenuResourceKeys.MenuSectionHeaderSpacing}">
        10
    </x:Double>
</ResourceDictionary>
