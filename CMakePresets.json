{
  "version": 10,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/engine/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vcpkg-overlays"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RETRO_WITH_CASE_PRESERVING_NAMES": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RETRO_WITH_CASE_PRESERVING_NAMES": "ON"
      }
    },
    {
      "name": "debug-game",
      "displayName": "Debug Game",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RETRO_WITH_CASE_PRESERVING_NAMES": "OFF"
      }
    },
    {
      "name": "packaged",
      "displayName": "Packaged",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RETRO_WITH_CASE_PRESERVING_NAMES": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "debug-game",
      "configurePreset": "debu-game",
      "configuration": "Debug"
    },
    {
      "name": "packaged",
      "configurePreset": "packaged",
      "configuration": "Release"
    }
  ]
}
