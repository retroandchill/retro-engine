<Project>
    <PropertyGroup>
        <RootSlnDir>$(MSBuildThisFileDirectory)</RootSlnDir>
        <EngineProjectsDir>$(RootSlnDir)/engine/src/runtime/dotnet/main</EngineProjectsDir>
        <RetroEngineProj>$(EngineProjectsDir)/RetroEngine/RetroEngine.csproj</RetroEngineProj>
        <RetroEngineCoreProj>$(EngineProjectsDir)/RetroEngine.Core/RetroEngine.Core.csproj</RetroEngineCoreProj>
        <RetroEngineHostProj>$(EngineProjectsDir)/RetroEngine.Host/RetroEngine.Host.csproj</RetroEngineHostProj>
        <RetroEngineLoggingProj>$(EngineProjectsDir)/RetroEngine.Logging/RetroEngine.Logging.csproj</RetroEngineLoggingProj>
        <RetroEnginePortableProj>$(EngineProjectsDir)/RetroEngine.Portable/RetroEngine.Portable.csproj</RetroEnginePortableProj>
        <RetroEnginePortableNativeProj>$(EngineProjectsDir)/RetroEngine.Portable/RetroEngine.Portable.Native.csproj</RetroEnginePortableNativeProj>
        <RetroEnginePortableCommonProj>$(EngineProjectsDir)/RetroEngine.Portable.Common/RetroEngine.Portable.Common.csproj</RetroEnginePortableCommonProj>
        <RetroEnginePortableSourceGeneratorProj>$(EngineProjectsDir)/RetroEngine.Portable.SourceGenerator/RetroEngine.Portable.SourceGenerator.csproj</RetroEnginePortableSourceGeneratorProj>

        <EditorProjectsDir>$(RootSlnDir)/engine/src/editor/dotnet/main</EditorProjectsDir>
        <RetroEngineEditorProj>$(EditorProjectsDir)/RetroEngine.Editor/RetroEngine.Editor.csproj</RetroEngineEditorProj>
        <RetroEngineEditorCoreProj>$(EditorProjectsDir)/RetroEngine.Editor.Core/RetroEngine.Editor.Core.csproj</RetroEngineEditorCoreProj>
        <RetroEngineEditorSourceGeneratorProj>$(EditorProjectsDir)/RetroEngine.Editor.SourceGenerator/RetroEngine.Editor.SourceGenerator.csproj</RetroEngineEditorSourceGeneratorProj>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Dev-Debug'">
        <RetroEngineBackend>Native</RetroEngineBackend>
        <RetroEngineCasePreservingNames>true</RetroEngineCasePreservingNames>
        <OutputPath>$(SolutionDir)/cmake-build-dev-debug/bin</OutputPath>
        <IntermediateOutputPath>$(SolutionDir)/cmake-build-dev-debug/obj/$(MSBuildProjectName)/</IntermediateOutputPath>
        <MSBuildProjectExtensionsPath>$(IntermediateOutputPath)</MSBuildProjectExtensionsPath>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
        <DefineConstants>$(DefineConstants);DEBUG</DefineConstants>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Dev-Release'">
        <RetroEngineBackend>Native</RetroEngineBackend>
        <RetroEngineCasePreservingNames>true</RetroEngineCasePreservingNames>
        <OutputPath>$(SolutionDir)/cmake-build-dev-release/bin</OutputPath>
        <IntermediateOutputPath>$(SolutionDir)/cmake-build-dev-release/obj/$(MSBuildProjectName)/</IntermediateOutputPath>
        <MSBuildProjectExtensionsPath>$(IntermediateOutputPath)</MSBuildProjectExtensionsPath>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Pkg-Debug'">
        <RetroEngineBackend>Native</RetroEngineBackend>
        <RetroEngineCasePreservingNames>false</RetroEngineCasePreservingNames>
        <OutputPath>$(SolutionDir)/cmake-build-pkg-debug/bin</OutputPath>
        <IntermediateOutputPath>$(SolutionDir)/cmake-build-pkg-debug/obj/$(MSBuildProjectName)/</IntermediateOutputPath>
        <MSBuildProjectExtensionsPath>$(IntermediateOutputPath)</MSBuildProjectExtensionsPath>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
        <DefineConstants>$(DefineConstants);DEBUG</DefineConstants>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Pkg-Release'">
        <RetroEngineBackend>Native</RetroEngineBackend>
        <RetroEngineCasePreservingNames>false</RetroEngineCasePreservingNames>
        <OutputPath>$(SolutionDir)/cmake-build-pkg-release/bin</OutputPath>
        <IntermediateOutputPath>$(SolutionDir)/cmake-build-pkg-release/obj/$(MSBuildProjectName)/</IntermediateOutputPath>
        <MSBuildProjectExtensionsPath>$(IntermediateOutputPath)</MSBuildProjectExtensionsPath>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    </PropertyGroup>

    <PropertyGroup
            Condition="'$(RetroEngineCasePreservingNames)' == 'true'"
    >
        <DefineConstants>$(DefineConstants);RETRO_WITH_CASE_PRESERVING_NAME</DefineConstants>
    </PropertyGroup>

    <ItemGroup Condition="'$(TargetFrameworkIdentifier)' != '.NETStandard'">
        <AssemblyAttribute Include="System.Runtime.CompilerServices.DisableRuntimeMarshalling"/>
    </ItemGroup>
</Project>
