<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RetroEngine.Editor.Core.ViewModels"
             xmlns:menus="clr-namespace:RetroEngine.Editor.Core.ViewModels.Menus"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RetroEngine.Editor.Core.Views.MainToolbar">
    <Design.DataContext>
        <menus:MenuBar/>
    </Design.DataContext>

    <StackPanel>
        <Menu ItemsSource="{Binding Items}">
            <Menu.Styles>
                <!-- Style for top-level MenuItem (SubMenuViewModel) -->
                <Style Selector="Menu > MenuItem" x:DataType="menus:SubMenuViewModel">
                    <Setter Property="Header" Value="{Binding Header}" />
                    <Setter Property="ItemsSource" Value="{Binding Children}"/>
                </Style>

                <Style Selector="MenuItem > MenuItem">
                    <Setter Property="Header" Value="{Binding Header}" />
                    <Setter Property="InputGesture" Value="{Binding InputGesture}"/>
                    <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                </Style>

                <Style Selector="MenuItem.separator">
                    <Setter Property="Header" Value="-"/>
                </Style>
            </Menu.Styles>
        </Menu>
    </StackPanel>
</UserControl>
