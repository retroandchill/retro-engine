<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RetroEngine.Editor.Core.ViewModels"
             xmlns:menus="clr-namespace:RetroEngine.Editor.Core.ViewModels.Menus"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RetroEngine.Editor.Core.Views.MainToolbar">
    <Design.DataContext>
        <menus:MenuBar/>
    </Design.DataContext>

    <StackPanel>
        <Menu>
            <MenuItem Header="File">
                <MenuItem Header="{Binding OpenText}" Command="{Binding OpenCommand}" InputGesture="Ctrl+O" IsEnabled="True"/>
                <MenuItem Header="{Binding SaveText}" Command="{Binding SaveCommand}" InputGesture="Ctrl+S" IsEnabled="True"/>
                <Separator/>
                <MenuItem Header="{Binding ExitText}" Command="{Binding ExitCommand}" IsEnabled="True"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="{Binding UndoCommand}" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z" IsEnabled="True"/>
                <MenuItem Header="{Binding RedoText}" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y" IsEnabled="True"/>
            </MenuItem>
        </Menu>
    </StackPanel>
</UserControl>
